# MongoDB Connection String (use MongoDB Atlas for cloud deployment)
# Format: mongodb+srv://username:password@cluster.mongodb.net/myDB?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/myDB

# OpenAI API Key (get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-api-key-here

# Admin password for API authentication
ADMIN_PASSWORD=your-secure-password-here

# Environment (development or production)
ENVIRONMENT=development

# Python server configuration (for production)
HOST=0.0.0.0
PORT=8000
